{
  "expo": {
    "name": "slate",
    "slug": "slate",
    "version": "1.0.0",
    "scheme": "slate",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.slate.app",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "slate finds and connects to your Mac on the local network.",
        "NSBonjourServices": ["_slate._tcp"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4f46e5",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.slate.app",
      "permissions": ["android.permission.ACCESS_LOCAL_NETWORK"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-image",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "backgroundColor": "#4f46e5"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "635a3f6c-deb2-4acb-893f-e7c860c8d1a6"
      }
    },
    "owner": "dav23"
  }
}
