{
  "name": "slate",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "verify": "pnpm -F @slate/protocol gen:schema --check && pnpm -F @slate/protocol test && pnpm -F @slate/node-helper test && pnpm -F @slate/protocol type-check && pnpm -F @slate/node-helper type-check && pnpm -F @slate/mobile type-check && biome check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/node": "^24.13.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "tsx": "4.22.4",
    "typescript": "5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  }
}
